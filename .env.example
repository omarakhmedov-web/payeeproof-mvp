# Base URL of your deployed service
BASE_URL=https://your-service-name.onrender.com

# Optional bearer token. If empty, auth is disabled for MVP demo.
API_BEARER_TOKEN=change-me

# SQLite database file path
DB_PATH=/tmp/payeeproof_mvp.db

# MVP defaults
DEFAULT_TTL_MINUTES=10
KEY_VERSION=ed25519-dev-v1

# Optional. Base64-encoded PEM private key for Ed25519.
# If omitted, the app generates an ephemeral demo key on boot.
SIGNING_PRIVATE_KEY_PEM_B64=
